    "@tailwindcss/typography": "^0.5.16",
    "apache-arrow": "^21.1.0",
    "cmdk": "^1.1.1",
    "dayjs": "^1.11.13",
    "dotenv": "^17.3.1",
    "html-to-image": "^1.11.13",
    "html2canvas": "^1.4.1",
    "inngest": "^3.54.0",
    "next": "^15.3.0",
    "next-themes": "^0.4.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.56.0",
