# ─────────────────────────────────────────────────────────────────────────────
# DeliveryOps environment variables
# Copy to .env.local and fill in. Never commit .env.local.
#
# For local-only dev: only the [LOCAL] vars are required. Everything marked
# [PROD] is needed for production / real integrations — until those are set,
# the integration falls back to a mock layer (see /dev page).
# ─────────────────────────────────────────────────────────────────────────────

# Anthropic — agent + Claude vision for document extraction.
# [LOCAL] required for the agent to do anything useful.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Supabase — Postgres + Storage + Auth (single source of truth).
# [LOCAL] required. With the Supabase CLI running (`npm run db:start`), the
# values are printed by `npm run db:status`. Defaults below match the CLI's
# default ports.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Inngest — durable background jobs.
# [LOCAL] not required when using the Inngest dev server (`npm run inngest:dev`)
# at localhost:8288 — the dev server picks up /api/inngest automatically.
# [PROD] required for cloud Inngest.
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Slack — Events API app, NOT socket-mode.
# [PROD] required. Without these, outbound Slack messages route to /dev/outbox
# and inbound is driven by the simulator at /dev/simulate.
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_ID=

# Google — single OAuth client covers Drive + Gmail + Calendar + Slides.
# [PROD] required. Without these, outbound email/Drive routes to /dev/outbox
# and Calendar reads return canned mock events.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_REFRESH_TOKEN=
GMAIL_PUBSUB_VERIFICATION_TOKEN=

# Salesforce
# [PROD] required (Phase 2).
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_INSTANCE_URL=

# Kognitos v2 — Bearer kgn_pat_...
# [PROD] required (Phase 2).
KOGNITOS_V2_TOKEN=
KOGNITOS_V2_BASE_URL=https://app.us-1.kognitos.com
KOGNITOS_V2_ORG_ID=
KOGNITOS_V2_WORKSPACE_ID=

# Kognitos v1 — x-api-key (legacy adapter, Phase 3).
KOGNITOS_V1_API_KEY=
KOGNITOS_V1_BASE_URL=https://rest-api.app.kognitos.com

# Monday.com
# [PROD] required (Phase 2).
MONDAY_API_TOKEN=

# App
SESSION_SECRET=
ALLOWED_EMAIL_DOMAIN=kognitos.com
# Same value, exposed to the client so the Google OAuth chooser can pre-filter
# to kognitos.com accounts and the login form can display the right placeholder.
# Server-side enforcement happens in /auth/callback regardless of this value.
NEXT_PUBLIC_ALLOWED_EMAIL_DOMAIN=kognitos.com

# Vercel Cron secret — header value Vercel sends with cron triggers.
# [LOCAL] optional. [PROD] strongly recommended.
CRON_SECRET=

# Force every integration into mock mode regardless of token presence.
# Useful for offline demos. Leave unset (or "auto") in normal use.
# Values: auto | on | off
DELIVERY_OPS_DEV_MODE=auto
