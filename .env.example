# ─────────────────────────────────────────────────────────────────────────────
# DeliveryOps environment variables
# Copy to .env.local and fill in. Never commit .env.local.
#
# [LOCAL] = required to run locally.  [PROD] = required in production.
# ─────────────────────────────────────────────────────────────────────────────

# Auth0 — authentication (sign-in, sign-out, session management).
# Create a Regular Web Application at https://manage.auth0.com
# Callback URLs:    http://localhost:4001/api/auth/callback
#                   https://<your-vercel-domain>/api/auth/callback
# Logout URLs:      http://localhost:4001
#                   https://<your-vercel-domain>
# Actions → Login:  add @kognitos.com email restriction (see lib/auth/auth0.ts)
# [LOCAL] required for sign-in to work.
AUTH0_SECRET=                         # openssl rand -hex 32
AUTH0_BASE_URL=http://localhost:4001  # change to Vercel URL in prod
AUTH0_ISSUER_BASE_URL=                # https://<tenant>.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# Anthropic — agent + Claude vision for document extraction.
# [LOCAL] required for the agent to do anything useful.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Supabase — Postgres + Storage (data layer only; auth handled by Auth0).
# [LOCAL] required. Run `npm run db:status` after `npm run db:start` for values.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Background jobs — Vercel Cron + fire-and-forget /api/jobs/*
# JOBS_SECRET protects /api/jobs/*. Falls back to CRON_SECRET if unset.
JOBS_SECRET=

# Vercel Cron secret — header Vercel sends with cron triggers.
# [LOCAL] optional. [PROD] strongly recommended.
CRON_SECRET=

# Slack — Events API app.
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_ID=

# Google — Drive + Gmail + Calendar + Slides.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_REFRESH_TOKEN=
GMAIL_PUBSUB_VERIFICATION_TOKEN=

# Salesforce
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_INSTANCE_URL=
# Pipeline Inspection list view for Dashboard upcoming deals (Binny Gill's Team default)
SALESFORCE_PIPELINE_LIST_VIEW_ID=00BQQ000001ZI7x2AG

# Kognitos v2 — Bearer kgn_pat_...
KOGNITOS_V2_TOKEN=
KOGNITOS_V2_BASE_URL=https://app.us-1.kognitos.com
KOGNITOS_V2_ORG_ID=
KOGNITOS_V2_WORKSPACE_ID=

# Kognitos v1 (legacy)
KOGNITOS_V1_API_KEY=
KOGNITOS_V1_BASE_URL=https://rest-api.app.kognitos.com

# Monday.com
MONDAY_API_TOKEN=

# Linear — read-only. Personal API key (Settings > Account > Security &
# Access). Used to sync ticket metadata for the V2 migration Tickets report;
# no write access needed and none is ever used (see lib/integrations/linear.ts).
LINEAR_API_TOKEN=

# App — domain restriction used by Auth0 hint + display text.
# The real enforcement is the Auth0 Action in your Login flow.
NEXT_PUBLIC_ALLOWED_EMAIL_DOMAIN=kognitos.com

# Force every integration into mock mode regardless of token presence.
# Values: auto | on | off
DELIVERY_OPS_DEV_MODE=auto
